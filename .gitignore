# kit-sync secrets — the live Notion token is kept OUT of git.
# It lives in ~/.config/kit_sync/notion_token (loaded by kit_sync_launch.sh).
# These patterns guard against ever committing a token from the repo tree:
scripts/kit_sync_secrets.sh
scripts/notion_token
*.token

# ── Secrets & credentials (never commit) ──
.config/
.claude-ssh/
**/.ssh/
*_token*
*token.txt
oura_token*
*.pem
*.key
.env
.env.*

# ── OS / editor noise ──
.DS_Store
**/.DS_Store
.~lock.*#

# ── Python ──
__pycache__/
*.pyc
*.bak

# ── Loose working files (notes, exports, helper scripts — not part of the web app) ──
*.xlsx
*.docx
*.pptx
/archive_deduped.py
/feedly_to_notion.py
/feedly-inbox-to-media-*.md
/nextdraft_summaries.md
scripts/*.command
/task-app/
